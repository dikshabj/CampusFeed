// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// --- ENUMS ---
enum Role {
  STUDENT
  FACULTY
  ADMIN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum DisputeStatus {
  OPEN
  APPROVED
  REJECTED
}

enum ExamType {
  MST1
  MST2
  FINAL
}

enum PostType {
  NOTICE
  ASSIGNMENT
  RESULT
  GENERAL
}

// --- MODELS ---

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  password        String
  role            Role      @default(STUDENT)
  name            String
  rollNumber      String?   @unique 
  facultyId       String?   @unique 
  profileImageUrl String?
  
  // Relations
  batchId         Int?
  batch           Batch?    @relation("StudentBatch", fields: [batchId], references: [id])
  
  mentoredBatches Batch[]   @relation("BatchMentor")
  subjects        Subject[] @relation("FacultySubjects")
  sessions        AttendanceSession[]
  records         AttendanceRecord[]
  disputesRaised  AttendanceDispute[] @relation("DisputeRaiser")
  disputesResolved AttendanceDispute[] @relation("DisputeResolver")
  marksUploaded   Mark[]    @relation("MarksUploader")
  marksReceived   Mark[]    @relation("StudentMarks")
  posts           Post[]

  createdAt       DateTime  @default(now())

  @@index([role])
}

model Batch {
  id        Int       @id @default(autoincrement())
  branch    String
  semester  Int
  section   String

  mentorId  Int?
  mentor    User?     @relation("BatchMentor", fields: [mentorId], references: [id])

  students  User[]    @relation("StudentBatch")
  subjects  Subject[]
  timetables Timetable[]
  posts     Post[]

  createdAt DateTime  @default(now())

  @@unique([branch, semester, section]) // Ensures no duplicate batches exist
  @@index([branch, semester, section])
}

model Subject {
  id        Int       @id @default(autoincrement())
  name      String
  code      String    @unique
  
  batchId   Int
  batch     Batch     @relation(fields: [batchId], references: [id])
  
  facultyId Int
  faculty   User      @relation("FacultySubjects", fields: [facultyId], references: [id])

  timetables Timetable[]
  sessions   AttendanceSession[]
  marks      Mark[]

  @@index([batchId])
  @@index([facultyId])
}

model Timetable {
  id        Int       @id @default(autoincrement())
  
  batchId   Int
  batch     Batch     @relation(fields: [batchId], references: [id])
  
  subjectId Int
  subject   Subject   @relation(fields: [subjectId], references: [id])
  
  dayOfWeek String    // e.g., "MONDAY", "TUESDAY"
  startTime String    // e.g., "09:00"
  endTime   String    // e.g., "10:00"

  @@index([batchId])
  @@index([dayOfWeek])
}

model AttendanceSession {
  id        Int       @id @default(autoincrement())
  date      DateTime  @default(now()) @db.Date // Stores only the date portion
  
  subjectId Int
  subject   Subject   @relation(fields: [subjectId], references: [id])
  
  createdBy Int
  faculty   User      @relation(fields: [createdBy], references: [id])

  records   AttendanceRecord[]

  createdAt DateTime  @default(now())

  @@unique([subjectId, date]) // Only one session per subject per day
}

model AttendanceRecord {
  id          Int               @id @default(autoincrement())
  status      AttendanceStatus
  
  sessionId   Int
  session     AttendanceSession @relation(fields: [sessionId], references: [id])
  
  studentId   Int
  student     User              @relation(fields: [studentId], references: [id])

  disputes    AttendanceDispute[]

  @@unique([sessionId, studentId]) // A student can only have one record per session
  @@index([studentId])
  @@index([sessionId])
}

model AttendanceDispute {
  id                 Int              @id @default(autoincrement())
  message            String
  status             DisputeStatus    @default(OPEN)
  
  attendanceRecordId Int
  record             AttendanceRecord @relation(fields: [attendanceRecordId], references: [id])
  
  raisedBy           Int
  student            User             @relation("DisputeRaiser", fields: [raisedBy], references: [id])
  
  resolvedBy         Int?
  faculty            User?            @relation("DisputeResolver", fields: [resolvedBy], references: [id])

  createdAt          DateTime         @default(now())

  @@index([attendanceRecordId])
  @@index([raisedBy])
}

model Mark {
  id          Int       @id @default(autoincrement())
  examType    ExamType
  marksObtained Float
  maxMarks    Float
  
  studentId   Int
  student     User      @relation("StudentMarks", fields: [studentId], references: [id])
  
  subjectId   Int
  subject     Subject   @relation(fields: [subjectId], references: [id])
  
  uploadedBy  Int
  faculty     User      @relation("MarksUploader", fields: [uploadedBy], references: [id])

  createdAt   DateTime  @default(now())

  @@unique([studentId, subjectId, examType]) // Prevents duplicate MST1 entries for the same subject
  @@index([studentId])
  @@index([subjectId])
}

model Post {
  id          Int       @id @default(autoincrement())
  title       String
  content     String
  type        PostType  @default(GENERAL)
  
  authorId    Int
  author      User      @relation(fields: [authorId], references: [id])
  
  batchId     Int?
  batch       Batch?    @relation(fields: [batchId], references: [id])

  expiryDate  DateTime?
  createdAt   DateTime  @default(now())

  @@index([batchId])
  @@index([createdAt])
  @@index([expiryDate])
}