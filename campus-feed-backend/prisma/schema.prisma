// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


//ENUMS:
enum Role{
  STUDENT //Can view feed , comment , make requests
  FACULTY //can create posts, manage requests
  ADMIN //can manage users
}

enum PostType {
  NOTICE
  EXAM
  ASSIGNMENT
  MATERIAL
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
enum RequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
}
//MODALS
model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String
  password String
  role      Role   @default(STUDENT)

  //login dtos
  rollNumber String? @unique
  teacherId String? @unique

  batch String?
  section String?

  mentorId Int?
  mentor User? @relation("StudentMentor", fields : [mentorId], references: [id])

  mentees User[] @relation("StudentMentor")


  //profile fields
  branch    String? 
  semester   Int?

  hashedRefreshToken String?

  //forget pass
  isEmailVerified Boolean @default(false)
  otp  String?
  otpExpiresAt DateTime?

  //relations
  posts  Post[]
  comments  Comment[]
  requests  AcademicRequest[]
  
  //for grades
  grades    Grade[]

  //attendence
  attendences Attendence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


}

model Post{
  id Int @id @default(autoincrement())
  title String
  description String
  type  PostType @default(NOTICE)
  status PostStatus @default(DRAFT)
  isPriority Boolean @default(false)

  //for s3 aws
  attachmentUrl String?
  attachmentType String?
  

  targetBranch String?
  targetSemester Int?

  //relations
  authorId Int
  author User @relation(fields: [authorId], references: [id])
  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment{
  id  Int @id @default(autoincrement())
  content String

  postId Int
  post Post @relation(fields: [postId], references: [id])

  authorId Int
  author User @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())

}

model AcademicRequest {
  id Int @id @default(autoincrement())
  title String
  description String
  status RequestStatus @default(OPEN)

  studentId Int
  student User  @relation(fields: [studentId] , references:[id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Grade{
  id Int @id @default(autoincrement())
  subject String 
  marks Float
  maxMarks Float
  term String

  studentId Int
  student User @relation(fields: [studentId], references: [id])

  createdAt DateTime @default(now())
}

model Attendence {
  id Int @id @default(autoincrement())
  date DateTime @default(now())
  subject String 
  status String

  //link to the students
  studentId Int
  student User @relation(fields: [studentId] , references : [id])
  dispute Dispute?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Dispute{
  id Int @id @default(autoincrement())
  reason String 
  status String @default("pending")

  attendenceId Int @unique
  attendence Attendence @relation(fields : [attendenceId] , references : [id])

  createdAt DateTime @default(now())
}